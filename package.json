  "browserslist": [
    "Chrome >= 105",
    "Firefox >= 104",
    "Safari >= 15.4",
    "Edge >= 105"
  ],
  "scripts": {
    "dev": "next dev",
    "generate:sitemap-routes": "npx tsx scripts/generate-sitemap-routes.ts",
